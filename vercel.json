{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist/public",
  "framework": null,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/trpc/[trpc].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/trpc/(.*)", "dest": "/api/trpc/[trpc]" },
    { "src": "/api/auth/(.*)", "dest": "/api/server" },
    { "src": "/api/oauth/(.*)", "dest": "/api/server" },
    { "src": "/manus-storage/(.*)", "dest": "/api/server" },
    { "src": "/((?!api/).*)", "dest": "/index.html" }
  ]
}
