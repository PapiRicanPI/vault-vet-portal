{
  "version": 2,
  "buildCommand": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist/server",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "routes": [
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
